rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /profiles/{userId} {
      // Only the signed-in owner can read/write their own profile document.
      allow read, create, update: if request.auth != null && request.auth.uid == userId;
      allow delete: if false;
    }

    // User visits subcollection - tracks places the user has visited
    match /users/{userId}/visits/{visitId} {
      // Only the signed-in owner can read/create their own visits.
      allow read, create: if request.auth != null && request.auth.uid == userId;
      // No updates or deletes - visits are permanent
      allow update, delete: if false;
    }

    // Deny all other collections/documents by default for MVP safety.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
