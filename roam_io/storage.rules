rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Profile photos - users can only read/write their own
    match /profile_photos/{userId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Visit media - users can only read/write their own
    match /visit_media/{userId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
